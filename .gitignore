*.swp
*.swo

# OS specific
.DS_Store
Thumbs.db
ehthumbs.db
Icon?
VolumeIcon.icns

# Coverage reports
coverage/
htmlcov/
.coverage

# Compressed files
*.zip
*.gz
*.tar
